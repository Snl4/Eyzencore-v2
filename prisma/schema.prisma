generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "sqlite"
}

model app_api_tokens {
  id           String       @id
  user_id      String
  server_id    Int?
  name         String
  token_hash   String       @unique(map: "sqlite_autoindex_app_api_tokens_2")
  scopes       String       @default("[\"servers:read\"]")
  last_used_at String?
  created_at   String
  revoked_at   String?
  app_users    app_users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_servers  app_servers? @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token_hash], map: "idx_api_tokens_token_hash")
  @@index([user_id], map: "idx_api_tokens_user_id")
  @@index([server_id], map: "idx_api_tokens_server_id")
}

model app_news_posts {
  id             Int       @id @default(autoincrement())
  author_user_id String
  title          String
  excerpt        String    @default("")
  content        String
  content_json   String    @default("[]")
  category       String    @default("Новини")
  cover_url      String?
  created_at     String
  updated_at     String
  app_users      app_users @relation(fields: [author_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_news_comments app_news_comments[]
  app_news_likes    app_news_likes[]
  app_news_views    app_news_views[]

  @@index([author_user_id], map: "idx_news_posts_author")
  @@index([created_at], map: "idx_news_posts_created_at")
}

model app_news_comments {
  id             Int            @id @default(autoincrement())
  news_id        Int
  user_id        String
  text           String
  created_at     String
  updated_at     String
  app_news_posts app_news_posts @relation(fields: [news_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_users      app_users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([news_id, user_id], map: "idx_news_comments_unique_user")
  @@index([news_id, created_at], map: "idx_news_comments_news")
  @@index([user_id], map: "idx_news_comments_user")
}

model app_news_likes {
  id             Int            @id @default(autoincrement())
  news_id        Int
  user_id        String
  created_at     String
  app_news_posts app_news_posts @relation(fields: [news_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_users      app_users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([news_id, user_id], map: "idx_news_likes_unique_user")
  @@index([news_id], map: "idx_news_likes_news")
  @@index([user_id], map: "idx_news_likes_user")
}

model app_news_views {
  id             Int             @id @default(autoincrement())
  news_id        Int
  user_id        String?
  fingerprint    String
  ip_address     String?
  user_agent     String?
  created_at     String
  app_news_posts app_news_posts  @relation(fields: [news_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_users      app_users?      @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([news_id, fingerprint], map: "idx_news_views_unique_fingerprint")
  @@unique([news_id, user_id], map: "idx_news_views_unique_user", where: raw("user_id IS NOT NULL"))
  @@index([news_id], map: "idx_news_views_news")
  @@index([created_at], map: "idx_news_views_created")
}

model app_notifications {
  id          Int          @id @default(autoincrement())
  user_id     String
  server_id   Int?
  type        String
  title       String
  body        String
  is_read     Int          @default(0)
  created_at  String
  app_servers app_servers? @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_users   app_users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_notifications_created_at")
  @@index([user_id], map: "idx_notifications_user_id")
}

model app_server_events {
  id          Int                          @id @default(autoincrement())
  server_id   Int
  owner_id    String
  type        String                       @default("update")
  title       String
  description String                       @default("")
  starts_at   String
  ends_at     String?
  location    String?
  prize       String?
  image_url   String?
  status      String                       @default("published")
  created_at  String
  updated_at  String
  app_servers app_servers                  @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_users   app_users                    @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attendees   app_server_event_attendees[]
  comments    app_server_event_comments[]

  @@index([server_id], map: "idx_server_events_server_id")
  @@index([starts_at], map: "idx_server_events_starts_at")
  @@index([status], map: "idx_server_events_status")
}

model app_server_event_attendees {
  id                Int               @id @default(autoincrement())
  event_id          Int
  user_id           String
  reminder_enabled  Int               @default(1)
  created_at        String
  app_server_events app_server_events @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_users         app_users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([event_id, user_id], map: "idx_server_event_attendees_unique")
  @@index([user_id], map: "idx_server_event_attendees_user")
}

model app_server_event_comments {
  id                Int               @id @default(autoincrement())
  event_id          Int
  user_id           String
  text              String
  created_at        String
  updated_at        String
  app_server_events app_server_events @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_users         app_users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([event_id, created_at], map: "idx_server_event_comments_event")
}

model app_projects {
  id                      Int                       @id @default(autoincrement())
  owner_id                String
  name                    String
  description             String?                   @default("")
  logo_url                String?
  website                 String?
  discord                 String?
  created_at              String
  updated_at              String
  app_users               app_users                 @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_server_applications app_server_applications[]
  app_servers             app_servers[]

  @@index([owner_id], map: "idx_projects_owner")
}

model app_clusters {
  id          Int           @id @default(autoincrement())
  owner_id    String
  name        String
  slug        String        @unique
  description String        @default("")
  logo_url    String?
  banner_url  String?
  website     String?
  discord     String?
  created_at  String
  updated_at  String
  app_users   app_users     @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_servers app_servers[]

  @@index([owner_id], map: "idx_clusters_owner")
}

model app_server_applications {
  id               Int           @id @default(autoincrement())
  owner_id         String
  status           String        @default("pending")
  rejection_reason String?
  name             String
  addr             String
  platform         String        @default("minecraft")
  mode             String
  ver              String
  core             String        @default("java")
  country          String?
  motd             String?
  short_desc       String?       @default("")
  full_desc        String?       @default("")
  desc             String?       @default("")
  website          String?
  discord          String?
  telegram         String?
  donate           String?
  tiktok           String?
  launcher_url     String?
  avatar_url       String?
  banner_url       String?
  gallery_json     String        @default("[]")
  videos_json      String        @default("[]")
  tags             String        @default("[]")
  owner_name       String?
  owner_avatar     String?
  created_at       String
  reviewed_at      String?
  project_id       Int?
  app_projects     app_projects? @relation(fields: [project_id], references: [id], onUpdate: NoAction)
  app_users        app_users     @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status], map: "idx_server_apps_status")
  @@index([owner_id], map: "idx_server_apps_owner_id")
}

model app_server_nickname_votes {
  id          Int         @id @default(autoincrement())
  server_id   Int
  nickname    String
  ip_address  String
  created_at  String
  app_servers app_servers @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_server_nickname_votes_created_at")
  @@index([ip_address], map: "idx_server_nickname_votes_ip")
  @@index([nickname], map: "idx_server_nickname_votes_nickname")
  @@index([server_id], map: "idx_server_nickname_votes_server_id")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model app_server_online_samples {
  server_id   Int
  online      Int         @default(0)
  players     Int         @default(0)
  max         Int         @default(0)
  votes       Int         @default(0)
  views       Int         @default(0)
  recorded_at String
  app_servers app_servers @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([server_id, recorded_at])
  @@index([recorded_at], map: "idx_server_online_samples_recorded_at")
  @@index([server_id], map: "idx_server_online_samples_server_id")
}

model app_server_reviews {
  id          Int         @id @default(autoincrement())
  server_id   Int
  user_id     String?
  fingerprint String
  author_name String?
  text        String
  rating      Int
  created_at  String
  updated_at  String
  app_users   app_users?  @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  app_servers app_servers @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([server_id, fingerprint], map: "idx_server_reviews_unique_fingerprint")
  @@unique([server_id, user_id], map: "idx_server_reviews_unique_user", where: raw("user_id IS NOT NULL"))
  @@index([fingerprint], map: "idx_server_reviews_fingerprint")
  @@index([user_id], map: "idx_server_reviews_user_id")
  @@index([server_id], map: "idx_server_reviews_server_id")
}

model app_server_verifications {
  id          Int         @id @default(autoincrement())
  server_id   Int         @unique(map: "sqlite_autoindex_app_server_verifications_1")
  owner_id    String
  token       String      @unique(map: "sqlite_autoindex_app_server_verifications_2")
  created_at  String
  verified_at String?
  app_users   app_users   @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_servers app_servers @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([owner_id], map: "idx_server_verifications_owner_id")
  @@index([server_id], map: "idx_server_verifications_server_id")
}

model app_server_views {
  id             Int         @id @default(autoincrement())
  server_id      Int
  user_id        String?
  fingerprint    String
  ip_address     String?
  country_code   String?
  referrer       String?
  traffic_source String?
  referral_code  String?
  created_at     String
  app_users      app_users?  @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  app_servers    app_servers @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([fingerprint], map: "idx_server_views_fingerprint")
  @@index([created_at], map: "idx_server_views_created_at")
  @@index([server_id], map: "idx_server_views_server_id")
  @@index([traffic_source], map: "idx_server_views_traffic_source")
  @@index([server_id, referral_code], map: "idx_server_views_referral_code")
}

model app_notification_preferences {
  user_id         String    @id
  enabled         Int       @default(1)
  votes_enabled   Int       @default(1)
  reviews_enabled Int       @default(1)
  system_enabled  Int       @default(1)
  updated_at      String
  app_users       app_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model app_server_votes {
  id          Int         @id @default(autoincrement())
  server_id   Int
  user_id     String?
  fingerprint String
  author_name String?
  value       Int         @default(1)
  created_at  String
  updated_at  String
  app_users   app_users?  @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  app_servers app_servers @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([server_id, fingerprint], map: "idx_server_votes_unique_fingerprint")
  @@unique([server_id, user_id], map: "idx_server_votes_unique_user", where: raw("user_id IS NOT NULL"))
  @@index([fingerprint], map: "idx_server_votes_fingerprint")
  @@index([user_id], map: "idx_server_votes_user_id")
  @@index([server_id], map: "idx_server_votes_server_id")
}

model app_server_likes {
  id          Int         @id @default(autoincrement())
  server_id   Int
  user_id     String?
  fingerprint String
  author_name String?
  created_at  String
  app_users   app_users?  @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  app_servers app_servers @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([server_id, fingerprint], map: "idx_server_likes_unique_fingerprint")
  @@unique([server_id, user_id], map: "idx_server_likes_unique_user", where: raw("user_id IS NOT NULL"))
  @@index([server_id], map: "idx_server_likes_server_id")
  @@index([user_id], map: "idx_server_likes_user_id")
}

model app_servers {
  id                        Int                         @id @default(autoincrement())
  owner_id                  String
  name                      String
  addr                      String                      @unique(map: "sqlite_autoindex_app_servers_1")
  platform                  String                      @default("minecraft")
  mode                      String
  ver                       String
  core                      String                      @default("java")
  country                   String?
  motd                      String?
  short_desc                String?                     @default("")
  full_desc                 String?                     @default("")
  desc                      String?                     @default("")
  website                   String?
  discord                   String?
  telegram                  String?
  donate                    String?
  tiktok                    String?
  launcher_url              String?
  avatar_url                String?
  banner_url                String?
  gallery_json              String                      @default("[]")
  videos_json               String                      @default("[]")
  tags                      String                      @default("[]")
  online                    Int                         @default(0)
  players                   Int                         @default(0)
  max                       Int                         @default(0)
  uptime                    String                      @default("new")
  verified                  Int                         @default(0)
  boosted                   Int                         @default(0)
  cluster_id                Int?
  created_at                String
  updated_at                String
  project_id                Int?
  discord_guild_id          String?
  discord_bot_verified      Int                         @default(0)
  discord_verify_code       String?
  app_notifications         app_notifications[]
  app_server_events         app_server_events[]
  app_api_tokens            app_api_tokens[]
  app_server_callback       app_server_callbacks?
  app_callback_events       app_callback_events[]
  app_callback_deliveries   app_callback_deliveries[]
  app_server_nickname_votes app_server_nickname_votes[]
  app_server_online_samples app_server_online_samples[] @ignore
  app_server_reviews        app_server_reviews[]
  app_server_likes          app_server_likes[]
  app_server_referrals      app_server_referrals[]
  app_server_verifications  app_server_verifications?
  app_server_views          app_server_views[]
  app_server_votes          app_server_votes[]
  app_projects              app_projects?               @relation(fields: [project_id], references: [id], onUpdate: NoAction)
  app_clusters              app_clusters?               @relation(fields: [cluster_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  app_users                 app_users                   @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([owner_id], map: "idx_app_servers_owner_id")
  @@index([addr], map: "idx_app_servers_addr")
  @@index([cluster_id], map: "idx_app_servers_cluster_id")
  @@index([boosted], map: "idx_app_servers_boosted")
}

model app_server_callbacks {
  id                  Int                       @id @default(autoincrement())
  server_id           Int                       @unique
  callback_url        String                    @default("")
  auth_header         String                    @default("Authorization")
  auth_token          String                    @default("")
  events_json         String                    @default("[\"vote\",\"comment\",\"like\"]")
  is_active           Int                       @default(0)
  nuvotifier_enabled  Int                       @default(0)
  nuvotifier_host     String                    @default("")
  nuvotifier_port     Int                       @default(8192)
  nuvotifier_token    String                    @default("")
  created_at          String
  updated_at          String
  app_servers         app_servers               @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  callback_deliveries app_callback_deliveries[]

  @@index([server_id], map: "idx_server_callbacks_server_id")
}

model app_server_referrals {
  id          Int         @id @default(autoincrement())
  server_id   Int
  owner_id    String
  label       String
  code        String
  channel     String      @default("custom")
  created_at  String
  updated_at  String
  disabled_at String?
  app_servers app_servers @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_users   app_users   @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([server_id, code], map: "idx_server_referrals_server_code")
  @@index([server_id], map: "idx_server_referrals_server_id")
  @@index([owner_id], map: "idx_server_referrals_owner_id")
}

model app_callback_events {
  id                  Int                       @id @default(autoincrement())
  server_id           Int
  action              String
  payload_json        String
  created_at          String
  app_servers         app_servers               @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  callback_deliveries app_callback_deliveries[]

  @@index([server_id, created_at], map: "idx_callback_events_server")
}

model app_callback_deliveries {
  id                   Int                  @id @default(autoincrement())
  event_id             Int
  callback_id          Int
  server_id            Int
  action               String
  destination          String
  payload_json         String
  status               String               @default("pending")
  status_code          Int?
  response_excerpt     String?
  error_message        String?
  created_at           String
  delivered_at         String?
  app_server_callbacks app_server_callbacks @relation(fields: [callback_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_callback_events  app_callback_events  @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_servers          app_servers          @relation(fields: [server_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([callback_id, created_at], map: "idx_callback_deliveries_callback")
  @@index([event_id], map: "idx_callback_deliveries_event")
  @@index([server_id, created_at], map: "idx_callback_deliveries_server")
}

model app_achievements {
  id                    Int                     @id @default(autoincrement())
  slug                  String                  @unique(map: "idx_app_achievements_slug")
  name                  String
  description           String                  @default("")
  emblem                String                  @default("★")
  image_url             String?
  trigger_type          String                  @default("manual")
  trigger_value         Int                     @default(0)
  is_active             Int                     @default(1)
  sort_order            Int                     @default(0)
  created_at            String
  updated_at            String
  app_user_achievements app_user_achievements[]

  @@index([is_active, sort_order], map: "idx_achievements_active_sort")
}

model app_user_achievements {
  id               Int              @id @default(autoincrement())
  achievement_id   Int
  user_id          String
  granted_by       String           @default("auto")
  earned_at        String
  app_achievements app_achievements @relation(fields: [achievement_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_users        app_users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([achievement_id, user_id], map: "idx_user_achievements_unique")
  @@index([user_id], map: "idx_user_achievements_user")
}

model app_users {
  id                         String                        @id
  email                      String                        @unique(map: "sqlite_autoindex_app_users_2")
  password_hash              String
  full_name                  String
  profile_slug               String?                       @unique(map: "sqlite_autoindex_app_users_3")
  bio                        String?                       @default("")
  location                   String?                       @default("")
  website                    String?
  telegram                   String?
  telegram_user_id           String?                       @unique(map: "idx_app_users_telegram_user_id", where: raw("telegram_user_id IS NOT NULL"))
  telegram_username          String?
  discord                    String?
  avatar_url                 String?
  banner_url                 String?
  role                       String                        @default("USER")
  is_legacy                  Int                           @default(0)
  theme                      String?                       @default("dark")
  created_at                 String
  updated_at                 String
  discord_user_id            String?                       @unique(map: "idx_app_users_discord_user_id", where: raw("discord_user_id IS NOT NULL"))
  app_api_tokens             app_api_tokens[]
  app_user_achievements      app_user_achievements[]
  app_news_comments          app_news_comments[]
  app_news_likes             app_news_likes[]
  app_news_posts             app_news_posts[]
  app_news_views             app_news_views[]
  app_notifications          app_notifications[]
  app_server_events          app_server_events[]
  app_server_event_attendees app_server_event_attendees[]
  app_server_event_comments  app_server_event_comments[]
  notification_preferences   app_notification_preferences?
  app_projects               app_projects[]
  app_clusters               app_clusters[]
  app_server_applications    app_server_applications[]
  app_server_reviews         app_server_reviews[]
  app_server_likes           app_server_likes[]
  app_server_referrals       app_server_referrals[]
  app_server_verifications   app_server_verifications[]
  app_server_views           app_server_views[]
  app_server_votes           app_server_votes[]
  app_servers                app_servers[]
  cms_sessions               cms_sessions[]
  forum_post_likes           forum_post_likes[]
  forum_posts                forum_posts[]
  forum_thread_likes         forum_thread_likes[]
  forum_threads              forum_threads[]
  password_reset_tokens      password_reset_tokens[]
  user_login_sessions        user_login_sessions[]

  @@index([email], map: "idx_app_users_email")
}

model password_reset_tokens {
  id         String    @id
  user_id    String
  token_hash String    @unique(map: "idx_password_reset_tokens_token_hash_unique")
  created_at String
  expires_at String
  used_at    String?
  app_users  app_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_password_reset_tokens_user_id")
  @@index([expires_at], map: "idx_password_reset_tokens_expires_at")
}

model forum_categories {
  id            Int             @id @default(autoincrement())
  slug          String          @unique
  name          String
  description   String          @default("")
  icon          String          @default("comments")
  color         String          @default("#7b8cff")
  position      Int             @default(0)
  created_at    String
  forum_threads forum_threads[]

  @@index([position], map: "idx_forum_categories_position")
}

model forum_threads {
  id                 Int                  @id @default(autoincrement())
  category_id        Int
  author_user_id     String
  title              String
  content            String
  attachments_json   String               @default("[]")
  is_pinned          Int                  @default(0)
  is_locked          Int                  @default(0)
  is_solved          Int                  @default(0)
  is_deleted         Int                  @default(0)
  deleted_at         String?
  deleted_by_user_id String?
  deleted_reason     String               @default("")
  moderation_reason  String               @default("")
  views              Int                  @default(0)
  created_at         String
  updated_at         String
  last_activity_at   String
  app_users          app_users            @relation(fields: [author_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  forum_categories   forum_categories     @relation(fields: [category_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  forum_posts        forum_posts[]
  forum_thread_likes forum_thread_likes[]

  @@index([author_user_id], map: "idx_forum_threads_author")
  @@index([category_id], map: "idx_forum_threads_category")
  @@index([last_activity_at], map: "idx_forum_threads_activity")
}

model forum_posts {
  id               Int                @id @default(autoincrement())
  thread_id        Int
  author_user_id   String
  content          String
  attachments_json String             @default("[]")
  created_at       String
  updated_at       String
  app_users        app_users          @relation(fields: [author_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  forum_threads    forum_threads      @relation(fields: [thread_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  forum_post_likes forum_post_likes[]

  @@index([author_user_id], map: "idx_forum_posts_author")
  @@index([thread_id, created_at], map: "idx_forum_posts_thread")
}

model forum_thread_likes {
  id            Int           @id @default(autoincrement())
  thread_id     Int
  user_id       String
  created_at    String
  app_users     app_users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  forum_threads forum_threads @relation(fields: [thread_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([thread_id, user_id], map: "idx_forum_thread_likes_unique")
  @@index([thread_id], map: "idx_forum_thread_likes_thread")
}

model forum_post_likes {
  id          Int         @id @default(autoincrement())
  post_id     Int
  user_id     String
  created_at  String
  app_users   app_users   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  forum_posts forum_posts @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([post_id, user_id], map: "idx_forum_post_likes_unique")
  @@index([post_id], map: "idx_forum_post_likes_post")
}

model cms_sessions {
  id         String    @id
  user_id    String
  token_hash String    @unique
  user_agent String?
  created_at String
  expires_at String
  revoked_at String?
  app_users  app_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token_hash], map: "idx_cms_sessions_token_hash")
  @@index([user_id], map: "idx_cms_sessions_user_id")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model email_verification_codes {
  email      String @id
  code_hash  String
  expires_at String
  sent_at    String
  attempts   Int    @default(0)
}

model app_site_settings {
  id                  Int    @id @default(1)
  maintenance_enabled Int    @default(0)
  maintenance_title   String @default("Технічні роботи")
  maintenance_message String @default("Ми оновлюємо Eyzencore. Сайт незабаром повернеться.")
  updated_at          String
}

model user_login_sessions {
  id         String    @id
  user_id    String
  token_hash String    @unique(map: "sqlite_autoindex_user_login_sessions_2")
  user_agent String?
  created_at String
  revoked_at String?
  app_users  app_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token_hash], map: "idx_sessions_token_hash")
  @@index([user_id], map: "idx_sessions_user_id")
}
