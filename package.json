{
  "name": "eyzencore",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "discord-bot": "tsx discord-bot/index.ts",
    "db:generate": "prisma generate",
    "db:pull": "prisma db pull",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:baseline": "prisma migrate resolve --applied 0001_baseline",
    "db:studio": "prisma studio",
    "db:smoke": "tsx scripts/prisma-smoke.ts",
    "db:audit": "tsx scripts/prisma-audit.ts",
    "db:verify": "npm run db:generate && prisma validate && prisma migrate status && npm run db:audit && npm run db:smoke",
    "db:import-nebula": "node scripts/import-nebula.cjs",
    "db:migrate-user-slugs": "node scripts/migrate-imported-user-slugs.cjs",
    "stats:collector": "tsx scripts/server-stats-collector.ts",
    "deploy:vps": "bash ./deploy.sh"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-toggle": "^1.1.11",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "discord.js": "^14.26.4",
    "framer-motion": "^11.0.0",
    "next": "14.2.29",
    "nodemailer": "^9.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "14.2.29",
    "postcss": "^8",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
