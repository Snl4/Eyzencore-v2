# =============================================================================
# Eyzencore — production .env template
# Copy to .env and fill values. Never commit .env to git.
# Canonical site URL: https://eyzencore.com (without www)
# =============================================================================

# --- Core ---
NODE_ENV=production
PORT=3001
DATABASE_URL=file:./data/eyzencore-auth.sqlite
MAINTENANCE_INTERNAL_ORIGIN=http://127.0.0.1:3001

# One canonical public URL (no www — nginx/middleware redirects www → apex)
NEXT_PUBLIC_APP_URL=https://eyzencore.com
APP_URL=https://eyzencore.com
FRONTEND_URL=https://eyzencore.com
API_PUBLIC_URL=https://eyzencore.com

# Session cookie: host-only (eyzencore.com). Do not set AUTH_COOKIE_DOMAIN unless subdomains need shared auth.
# AUTH_COOKIE_DOMAIN=

# --- Auth / security ---
JWT_SECRET=change-me-long-random-string
ADMIN_EMAIL=admin@example.com
BOB_ADMIN_EMAIL=admin@example.com

# --- Discord OAuth (login + link account) ---
# Developer Portal → OAuth2 → Redirects MUST include DISCORD_REDIRECT_URI exactly
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://eyzencore.com/api/auth/discord/callback
DISCORD_OAUTH_STATE_SECRET=change-me-random-string

# --- Discord bot (verification /link, guild sync) ---
DISCORD_BOT_TOKEN=
DISCORD_BOT_SECRET=change-me-same-on-site-and-bot-process
DISCORD_GUILD_ID=
DISCORD_ROLE_LINKED_ID=
DISCORD_ROLE_SERVER_OWNER_ID=
DISCORD_ROLE_NEW_MEMBER_ID=
DISCORD_LINK_TTL_MINUTES=10
DISCORD_ENABLE_MEMBER_EVENTS=1
DISCORD_ENABLE_NEWS_SLASH=1
DISCORD_NEWS_CHANNEL_ID=
DISCORD_NEWS_ALLOWED_ROLE_ID=
DISCORD_NEWS_COMMAND_PREFIX=!news

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://eyzencore.com/api/auth/google/callback
GOOGLE_OAUTH_STATE_SECRET=change-me-random-string

# --- Microsoft OAuth (if used) ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Email (registration codes, password reset) ---
DISABLE_EMAIL_VERIFICATION=false
EMAIL_FROM=noreply@eyzencore.com
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# --- reCAPTCHA ---
RECAPTCHA_ENABLED=1
RECAPTCHA_SECRET_KEY=
VITE_RECAPTCHA_SITE_KEY=

# --- Telegram (site bot) ---
TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_BOT_USERNAME=EyzenCore_bot

# --- Minecraft avatar Telegram bot (npm run avatar:bot) ---
AVATAR_BOT_TOKEN=
AVATAR_BOT_NAME=HEADMC_Avatar
AVATAR_BOT_RENDER_MODE=blender
AVATAR_BOT_BLENDER_PATH=blender
AVATAR_BOT_BLEND_FILE=avatar-bot/blender/minecraft_avatar.blend
AVATAR_BOT_BLENDER_TIMEOUT_MS=120000

# --- Frontend (Vite legacy / client hints) ---
VITE_API_BASE_URL=/api
VITE_MAIN_SITE_ORIGIN=https://eyzencore.com
VITE_DISCORD_COMMUNITY_INVITE=https://discord.gg/your-invite
VITE_DONATE_DOMAIN=eyzencore.com
VITE_GIVEAWAY_FALLBACK_SLUG=giveaway-2
GIVEAWAY_ALLOW_DUPLICATE_IP=0

# --- Optional integrations ---
PLAYTIME_API_SECRET=
LOG_PLAYTIME_EVENTS=true

# --- News bot (npm run news:bot) ---
NEWS_BOT_AUTHOR_EMAIL=
TELEGRAM_NEWS_CHANNEL_ID=
NEWS_BOT_LIMIT=1
