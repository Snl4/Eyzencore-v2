# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
MAINTENANCE_INTERNAL_ORIGIN=http://127.0.0.1:3000
DATABASE_URL=file:./data/eyzencore-auth.sqlite

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
DISCORD_OAUTH_STATE_SECRET=change-me-to-random-string

# SMTP email verification
DISABLE_EMAIL_VERIFICATION=false
EMAIL_FROM=noreply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Discord Bot
DISCORD_BOT_TOKEN=
DISCORD_BOT_SECRET=change-me-to-random-string

# News bot
# Run: npm run news:bot:dry / npm run news:bot
NEWS_BOT_AUTHOR_EMAIL=
TELEGRAM_NEWS_CHANNEL_ID=
NEWS_BOT_LIMIT=1
# Optional: improves rewriting/translating to Ukrainian.
NEWS_BOT_OPENAI_API_KEY=
NEWS_BOT_OPENAI_MODEL=gpt-4o-mini
# Optional custom sources, comma or newline separated:
# kind|Label|URL
# Supported kind: rss, reddit, telegram, web, x
# Telegram example: telegram|Minecraft UA|https://t.me/s/channel_name
# X needs a public mirror/RSS/API URL that can be fetched without browser auth.
NEWS_BOT_SOURCES=
NEWS_BOT_FETCH_TIMEOUT_MS=12000
